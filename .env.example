# MongoDB Atlas connection string (include /dbname in URI, or set MONGO_DB_NAME below)
MONGO_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/nas?retryWrites=true&w=majority
# Optional: required if MONGO_URI has no path (e.g. mongodb://127.0.0.1:27017)
# MONGO_DB_NAME=nas
# Optional: custom CA bundle PEM for Atlas TLS (default: certifi)
# MONGO_TLS_CA_FILE=/path/to/ca.pem

# JWT signing (use a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# Local NAS storage (mount point on Raspberry Pi)
STORAGE_PATH=/mnt/nas_storage

# Max upload size in bytes (e.g. 500 MiB)
MAX_UPLOAD_SIZE=524288000

# Device sync (Phase 3 — mobile gallery backup)
SYNC_ENABLED=true
# Suggested client heartbeat interval (seconds); returned at device registration
HEARTBEAT_INTERVAL=30
# If no heartbeat for this many seconds, device shows offline in API
DEVICE_TIMEOUT=120

# App
APP_NAME="NAS Core API"
DEBUG=false
ENVIRONMENT=development
# Local SPA CORS bypass if the shell exports ENVIRONMENT=production (overrides .env)
# NAS_CORS_DEV=true
# Comma-separated; required when using credentials from the SPA
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080
# Shown in startup logs — keep in sync with how you run uvicorn (run.sh uses these)
API_HOST=0.0.0.0
API_PORT=8000

# Block storage (USB/HDD on Pi): mount/unmount/format need root; keep off until configured
# NAS_STORAGE_OPS_ENABLED=false
# NAS_FORMAT_ENABLED=false
# Comma-separated parent paths allowed for mount points (UI + API validation)
# STORAGE_MOUNT_ALLOW_PREFIXES=/mnt,/media
